# =============================================================================
# Ex-sRNA-NF .gitignore
# =============================================================================
# This file is intentionally exhaustive. Every category is commented to explain
# why it is excluded. When in doubt, exclude it here and use `git add -f` to
# force-add a specific file if it genuinely belongs in version control.
# =============================================================================


# =============================================================================
# NEXTFLOW RUNTIME FILES
# These are generated by every Nextflow run and must never be committed.
# They contain absolute paths, timestamps, and machine-specific metadata
# that change on every execution and are meaningless outside the original host.
# =============================================================================

# Nextflow work directory — contains all intermediate files, staged inputs,
# cached process outputs, and symlinks. Can be tens to hundreds of GB.
work/

# Nextflow session history and cache database
.nextflow/
.nextflow.log
.nextflow.log.*

# Nextflow execution reports generated by -with-report, -with-trace, -with-dag
execution_report*.html
execution_timeline*.html
execution_trace*.txt
dag.mmd
dag.html
dag.dot
trace.txt
report.html
timeline.html


# =============================================================================
# PIPELINE RESULTS
# Output files produced by the pipeline are not stored in the repository.
# They are large, reproducible from inputs, and organism/data-specific.
# Results should be stored on lab servers or in a data repository (e.g. Zenodo).
# =============================================================================

results/


# =============================================================================
# INPUT DATA
# Raw sequencing data and reference genomes are never committed to git.
# They are too large for GitHub (>100 MB file limit) and should be stored
# on lab servers or downloaded from their original sources.
# =============================================================================

# Raw sequencing libraries
exRNA_Species/
exRNA_*/

# Reference genomes and pre-computed annotation FASTAs
genome/

# Any loose FASTQ or FASTA files at the project root (safety catch)
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.fa
*.fasta
*.fna

# Genome index files (bowtie2, bowtie, STAR, etc.)
*.bt2
*.bt2l
*.ebwt
*.ebwtl
*.1.bt2
*.2.bt2
*.3.bt2
*.4.bt2
*.rev.1.bt2
*.rev.2.bt2

# BAM/SAM alignment files
*.bam
*.bam.bai
*.bam.csi
*.sam
*.cram
*.crai


# =============================================================================
# LARGE INTERMEDIATE AND OUTPUT FILE TYPES
# These extensions represent file types that are either too large for git,
# reproducible by the pipeline, or both. Caught here as a safety net even
# if the results/ directory exclusion above already covers most cases.
# =============================================================================

# Compressed archives
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.bz2
*.xz
*.zip
*.zst

# Large tabular outputs
*.csv
*.tsv
*.txt

# PDF and image outputs
*.pdf
*.png
*.jpg
*.jpeg
*.svg
*.eps
*.tiff
*.tif

# HDF5 and other binary data formats
*.h5
*.hdf5
*.hdf
*.nc
*.npz
*.npy
*.pkl
*.pickle
*.rds
*.RData


# =============================================================================
# CONDA AND VIRTUAL ENVIRONMENTS
# Environment directories are machine-specific and should be reproduced
# from environment.yml, not committed. The environment.yml spec file IS
# committed (it is not excluded here).
# =============================================================================

# Conda environments
envs/
.conda/
conda-env/
miniconda/
miniforge/
mambaforge/
.mamba/

# Python virtual environments
venv/
.venv/
env/
.env/
ENV/
__pypackages__/

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyc
.Python

# Python packaging artifacts
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl


# =============================================================================
# NODE.JS
# If any utility scripts use Node.js/npm (e.g. mermaid-cli, mmdc)
# =============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
package-lock.json
yarn.lock
.pnp
.pnp.js


# =============================================================================
# R
# R session files and package caches should not be committed.
# R scripts used for downstream analysis SHOULD be committed.
# =============================================================================

.Rhistory
.RData
.Rproj.user/
*.Rproj
renv/
renv.lock


# =============================================================================
# JUPYTER NOTEBOOKS — OUTPUTS ONLY
# Notebook source (.ipynb) files are committed, but their output cells
# (which can contain large base64-encoded images and data) should be
# cleared before committing. Use `jupyter nbconvert --clear-output` or
# the nbstripout pre-commit hook.
# =============================================================================

# Jupyter checkpoint files (auto-generated on every save)
.ipynb_checkpoints/
*/.ipynb_checkpoints/


# =============================================================================
# OPERATING SYSTEM FILES
# Generated by macOS, Windows, and Linux file managers. Never meaningful
# in a repository.
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# =============================================================================
# EDITOR AND IDE FILES
# Project-specific settings for editors should use global gitignore
# (~/.gitignore_global) rather than the repository gitignore, but these
# are included here for robustness.
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Vim
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist
tags

# Emacs
*~
\#*\#
.\#*
.emacs.desktop
.emacs.desktop.lock
auto-save-list
tramp
.\#*

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project

# Nano
*.save


# =============================================================================
# CREDENTIALS AND SECRETS
# These must NEVER be committed under any circumstances.
# If a credential is accidentally committed, treat it as compromised
# immediately — rotate it, then use `git filter-branch` or BFG Repo Cleaner
# to purge it from history.
# =============================================================================

.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
secrets.yml
secrets.yaml
secrets.json
credentials
credentials.json
*_credentials*
*_secrets*
token
token.txt
*.token
config_private*
private_config*
auth.cfg


# =============================================================================
# SLURM AND HPC SCHEDULER FILES
# Job submission logs and error files accumulate quickly and are not
# meaningful outside the original cluster environment.
# =============================================================================

slurm-*.out
slurm-*.err
*.qsub
*.pbs
*.lsf
.slurm/
sge_output/
job_logs/


# =============================================================================
# TEMPORARY AND LOG FILES
# =============================================================================

*.log
*.tmp
*.temp
*.bak
*.orig
*.rej
*.patch
*.diff
tmp/
temp/
logs/
log/
cache/
.cache/


# =============================================================================
# MD5 AND CHECKSUM FILES
# These are data-specific and generated alongside input data.
# =============================================================================

*.md5
*md5sum*
*.sha256
*.sha512
checksums.txt


# =============================================================================
# EXCEPTIONS — files that would otherwise be caught by rules above
# but SHOULD be tracked. Use `!` to un-exclude specific files.
# =============================================================================

# The conda environment specification is always committed
!environment.yml

# The nextflow config is always committed
!nextflow.config

# Example or template .env files (no real secrets)
!.env.example

# bin/ scripts are always committed (Nextflow adds bin/ to $PATH automatically)
!bin/
!bin/*.py

# modules/ DSL2 process files are always committed
!modules/
!modules/*.nf

# The pipeline entrypoint is always committed
!main_sRNA.nf
